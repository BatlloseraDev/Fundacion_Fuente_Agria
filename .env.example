# --- Configuración de MySQL ---
MYSQL_ROOT_PASSWORD=root_password # Cambia esto por una contraseña segura
MYSQL_USER=admin
MYSQL_PASSWORD=admin
MYSQL_DATABASE=fuenteagria_db
DB_HOST=mysql
DB_PORT=3306


# Configuración de PgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Cadena de conexión para Prisma (Backend NestJS)
# Formato: mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${DB_HOST}:${DB_PORT}/${MYSQL_DATABASE}?allowPublicKeyRetrieval=true&ssl=false

#seguridad
JWT_SECRET=fuenteagria_fan_hardcodeado
JWT_EXPIRES_IN=7d

